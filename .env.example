# JWT Secret (WICHTIG: Ändern!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Hugging Face Token (optional)
HF_TOKEN=your_hf_token_here

# Database
DATABASE_URL=sqlite:///./data/db/app.db

# LLM Model
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Whisper Model
WHISPER_MODEL=openai/whisper-small

# TTS Model
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2

# System Prompt
SYSTEM_PROMPT=Du bist Dr. Lila, eine empathische KI-Therapeutin. Du hörst zu, stellst therapeutische Fragen und hilfst Menschen durch schwierige Zeiten.

# RAG
RAG_ENABLED=true
RAG_TOP_K=3

# Debug
DEBUG=false